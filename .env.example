# Gateway Configuration
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0
DB_PATH=./agentguard.db

# Redis Configuration
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

# PostgreSQL Configuration (for future migration)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentguard
POSTGRES_USER=agentguard
POSTGRES_PASSWORD=changeme

# Safety Policies
DEFAULT_RISK_THRESHOLD=MEDIUM
AUTO_APPROVE_BELOW=LOW

# Kill Switch Configuration
KILL_SWITCH_MAX_VIOLATIONS=3
KILL_SWITCH_WINDOW=3600

# MCP Configuration
MCP_TIMEOUT=30000
MCP_MAX_CONCURRENT=100

# OpenTelemetry Configuration
OTEL_ENABLED=true
OTEL_ENDPOINT=http://localhost:4317

# Compliance Cockpit Configuration
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# Python SDK Configuration
AGENTGUARD_AGENT_ID=your-agent-id-here
AGENTGUARD_GATEWAY_URL=http://localhost:8080
AGENTGUARD_PRIVATE_KEY_PATH=/path/to/private.key

# Development Settings
NODE_ENV=development
LOG_LEVEL=debug